# Required
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-bucket-name

# Optional
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=              # leave blank for AWS S3; set for R2 or MinIO
S3_PREFIX=varimat/             # folder prefix inside the bucket, or leave blank
